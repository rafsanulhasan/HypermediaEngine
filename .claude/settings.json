{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(dotnet sln:*)",
      "Bash(dotnet --version)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(dotnet stryker:*)",
      "Bash(dotnet run:*)",
      "Bash(dotnet add package:*)",
      "Bash(dotnet add reference:*)",
      "Bash(dotnet remove package:*)",
      "Bash(dotnet remove reference:*)",
      "Bash(dotnet list package:*)",
      "Bash(dotnet list reference:*)",
      "Bash(git --version)",
      "Bash(git status)",
      "Bash(git add:*)",
      "Bash(git push:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  }
}
